<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <bean id ="myBean" class="com.example.demo.GreetingService"/>
    <bean id="EmailNotificationServices" class="com.example.loose.EmailNotificationService"/>
    <bean id="SMSNotificationServices" class="com.example.loose.SMSNotificationService"/>
    <bean id="UserServiceEmail" class="com.example.loose.UserService">
        <property name="notificationService" ref="EmailNotificationServices"/>
    </bean>
    <bean id="UserServiceSMS" class="com.example.loose.UserService">
        <property name="notificationService" ref="SMSNotificationServices"/>
    </bean>
</beans>